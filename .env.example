# ---------------------------------------------------------------------------
# Naxeu Community Edition — example environment configuration
# Copy this file to `.env` and adjust values. No real secrets are committed.
# ---------------------------------------------------------------------------

# --- Node / general ---
NODE_ENV=development

# --- PostgreSQL ---
# When running via docker compose, host is the service name `postgres`.
POSTGRES_USER=naxeu
POSTGRES_PASSWORD=naxeu
POSTGRES_DB=naxeu
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Full connection string used by the api/worker/db packages.
DATABASE_URL=postgres://naxeu:naxeu@postgres:5432/naxeu

# --- Redis (realtime pub/sub + worker queue) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# --- API ---
API_HOST=0.0.0.0
API_PORT=3000
# CHANGE THIS in production. Used to sign JWT auth tokens.
JWT_SECRET=change-me-in-production-please-32-chars-min
# Comma separated list of allowed CORS origins for the PWA.
CORS_ORIGIN=http://localhost:5173

# --- Web / PWA (Vite build-time vars, must be prefixed with VITE_) ---
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000

# --- File storage (local disk for the community edition) ---
STORAGE_DIR=/data/storage

# --- Config files (YAML) ---
CONFIG_DIR=/app/config

# --- AI (optional overrides; base settings still come from config/ai.yml) ---
# Global switches (unset = use YAML):
# AI_ENABLED=true|false|1|0|yes|no|on|off
# AI_DEFAULT_PROVIDER=mock|openai|anthropic|local
AI_ENABLED=
AI_DEFAULT_PROVIDER=
# Per-task provider/model (UPPER_SNAKE task name). Examples:
# AI_TASK_QUICK_INPUT_PARSING_PROVIDER=openai
# AI_TASK_QUICK_INPUT_PARSING_MODEL=gpt-4o-mini
# AI_TASK_TRANSACTION_CATEGORIZATION_PROVIDER=openai
# AI_TASK_TRANSACTION_CATEGORIZATION_MODEL=gpt-4o-mini
# AI_TASK_ATTACHMENT_EXTRACTION_PROVIDER=openai
# AI_TASK_ATTACHMENT_EXTRACTION_MODEL=gpt-4o-mini
# AI_TASK_MONTHLY_SUMMARY_PROVIDER=openai
# AI_TASK_MONTHLY_SUMMARY_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- SMTP (optional — mock transport is used when unset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Web Push (optional — generate with `npx web-push generate-vapid-keys`) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@naxeu.com
