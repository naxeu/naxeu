# Full workspace image for local development (bind-mount source over apps/packages).
# Used by docker-compose.dev.yml — not for production.
FROM node:22-slim
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable
WORKDIR /app

COPY pnpm-workspace.yaml package.json pnpm-lock.yaml tsconfig.base.json ./
COPY packages ./packages
COPY apps ./apps
RUN pnpm install --frozen-lockfile

COPY config ./config
COPY branding ./branding

ENV NODE_ENV=development
ENV CONFIG_DIR=/app/config
ENV BRANDING_DIR=/app/branding

EXPOSE 3000 5173
WORKDIR /app
CMD ["sh", "-c", "echo 'Use docker compose dev override command (pnpm dev:api / dev:web / dev:worker).' && sleep infinity"]
