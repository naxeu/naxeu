{
  "name": "@naxeu/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host --port 5173",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "lint": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@naxeu/shared": "workspace:*",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vuetify": "^3.7.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "sass-embedded": "^1.83.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "vite-plugin-vuetify": "^2.0.4",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  }
}
