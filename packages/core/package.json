    "@naxeu/db": "workspace:*",
    "@naxeu/shared": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
